# Salin ke `.env` lalu sesuaikan (di-load oleh shell/PM2, bukan oleh Go langsung).

# Port HTTP API.
MARKETING_PORT=8086

# CORS allowed origin (gunakan domain frontend di produksi, mis. https://app.greenpark...).
MARKETING_ALLOW_ORIGIN=*

# Lokasi file JSON master data (dipakai jika MARKETING_DATABASE_URL kosong).
MARKETING_DATA_PATH=data/marketing-data.json

# DSN PostgreSQL. Jika di-set, store DB dipakai menggantikan file JSON.
# MARKETING_DATABASE_URL=postgres://user:pass@localhost:5432/greenpark?sslmode=disable
